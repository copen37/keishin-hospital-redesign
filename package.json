{
  "name": "keishin-hospital-redesign",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist",
    "build:css": "tailwindcss -c tailwind.config.js -i ./src/assets/css/main.css -o ./dist/assets/css/main.css --minify",
    "build:site": "eleventy",
    "build": "npm run clean && npm run build:site && npm run build:css && node scripts/generate-sitemap.mjs",
    "dev": "eleventy --serve",
    "audit": "node scripts/playwright-audit.mjs"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "playwright": "^1.52.0",
    "tailwindcss": "^3.4.17"
  }
}
