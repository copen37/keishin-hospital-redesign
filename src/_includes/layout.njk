<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} | {{ site.name }}</title>
  <meta name="description" content="{{ description or site.description }}" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="{{ title }} | {{ site.name }}" />
  <meta property="og:description" content="{{ description or site.description }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:image" content="{{ site.url }}{{ ogImage or site.ogImage }}" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="stylesheet" href="{{ '/assets/css/main.css' | url }}" />
</head>
<body>
  <a href="#main" class="skip-link">本文へスキップ</a>

  <div class="ticker" role="status" aria-live="polite">
    <div class="container-keishin flex items-center gap-4 overflow-hidden py-2">
      <span class="ticker-label">INFORMATION</span>
      <p class="ticker-track">外来受付 8:30–11:30 / 13:30–16:30　・　急患は24時間対応（事前連絡推奨）　・　採用情報を更新しました</p>
    </div>
  </div>

  <header class="site-header">
    <div class="container-keishin">
      <div class="hidden lg:flex items-center justify-between py-4 gap-8">
        <a href="{{ '/' | url }}" class="text-2xl font-black text-brand-900 tracking-tight">{{ site.name }}</a>
        <nav aria-label="グローバルナビゲーション">
          <ul class="flex items-center gap-6 text-sm font-medium">
            {% for item in navigation %}
            <li><a href="{{ item.url | url }}" class="nav-link">{{ item.label }}</a></li>
            {% endfor %}
          </ul>
        </nav>
        <div class="flex items-center gap-2">
          <a href="{{ '/access/' | url }}" class="btn-secondary text-sm">お問い合わせ</a>
          <a href="tel:{{ site.phone | replace('-', '') }}" class="btn-primary text-sm">{{ site.phone }}</a>
        </div>
      </div>

      <div class="lg:hidden py-3 flex items-center justify-between gap-4">
        <a href="{{ '/' | url }}" class="font-extrabold text-lg text-brand-900">{{ site.name }}</a>
        <details class="mobile-menu">
          <summary aria-label="メニューを開く" class="btn-secondary text-sm list-none cursor-pointer">メニュー</summary>
          <div class="mobile-panel" role="dialog" aria-label="モバイルメニュー">
            <ul class="space-y-3 pb-4 border-b border-slate-200">
              {% for item in navigation %}
              <li><a href="{{ item.url | url }}" class="block py-1">{{ item.label }}</a></li>
              {% endfor %}
            </ul>
            <div class="pt-4 grid gap-2">
              <a href="{{ '/access/' | url }}" class="btn-secondary text-sm">お問い合わせ</a>
              <a href="tel:{{ site.phone | replace('-', '') }}" class="btn-primary text-sm">{{ site.phone }}</a>
            </div>
          </div>
        </details>
      </div>
    </div>
  </header>

  <main id="main">{{ content | safe }}</main>

  <div class="floating-cta" aria-label="固定CTA">
    <a href="tel:{{ site.phone | replace('-', '') }}" class="floating-btn">電話</a>
    <a href="{{ '/access/' | url }}" class="floating-btn">予約・問合せ</a>
  </div>

  <footer class="mt-24 bg-brand-900 text-brand-50">
    <div class="container-keishin py-16 grid md:grid-cols-3 gap-10">
      <div>
        <p class="font-bold text-lg mb-2">{{ site.name }}</p>
        <p class="text-sm opacity-90">{{ site.address }}</p>
        <p class="text-sm opacity-90 mt-1">代表 {{ site.phone }} / {{ site.hours }}</p>
      </div>
      <div>
        <p class="font-semibold mb-3">サイトメニュー</p>
        <ul class="space-y-2 text-sm">
          {% for item in navigation %}<li><a href="{{ item.url | url }}" class="hover:underline">{{ item.label }}</a></li>{% endfor %}
        </ul>
      </div>
      <div>
        <p class="font-semibold mb-3">来院前のご案内</p>
        <p class="text-sm opacity-90 mb-4">初診・紹介状に関するご相談はお気軽にご連絡ください。</p>
        <a href="{{ '/hospitalization/' | url }}" class="btn-secondary !border-white !text-white hover:!bg-white/15">入院案内を見る</a>
      </div>
    </div>
    <div class="border-t border-white/20 py-4 text-center text-xs">© 2026 {{ site.name }}</div>
  </footer>
</body>
</html>