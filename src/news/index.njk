---
layout: layout.njk
title: お知らせ一覧
---
<section class="container-keishin py-14">
  <h1 class="section-title">お知らせ一覧</h1>
  <ul class="mt-8 space-y-4">
    {% for item in news %}
    <li class="card">
      <p class="text-xs text-slate-500 mb-1">{{ item.date }} / {{ item.category }}</p>
      <a class="text-lg font-semibold hover:text-brand-700" href="/news/{{ item.slug }}/">{{ item.title }}</a>
      <p class="mt-2 text-sm">{{ item.summary }}</p>
    </li>
    {% endfor %}
  </ul>
</section>
